#!/usr/bin/env bash
# purplevoice-record — Phase 2 hardened bash glue (PurpleVoice)
# Owns sox capture + transcription pipeline. Pattern 2 boundary: the whisper-cli
# binary reference appears on exactly two lines (assignment + single use inside
# the transcribe function) — this is the v1.1 swap site for warm-process upgrade.
#
# Phase 2 additions over Phase 1:
#   - VAD flags + Silero model in transcribe() body (TRA-04)
#   - Duration gate via soxi -D (TRA-05)
#   - Denylist exact-match filter (TRA-06)
#   - Empty/whitespace transcript drop (INJ-04)
#   - TCC stderr fingerprint detection (ROB-02)
#   - EXIT trap covering ALL exit paths including SIGINT (ROB-04)
#   - Semantic exit codes 2/3/10/11/12 for Lua dispatch
#   - --no-prints + removal of file-output flags (Phase-1 TODO c — suppress sibling .txt)
#   - PURPLEVOICE_TEST_SKIP_SOX env var hook for tests/test_*.sh

set -euo pipefail

# --- Absolute binary paths (Pitfall 2, ROB-03) -------------------------
# hs.task does NOT include /opt/homebrew/bin in PATH on Apple Silicon.
# Override via env vars if you're on Intel (/usr/local/bin) or custom install.
SOX_BIN="${SOX_BIN:-/opt/homebrew/bin/sox}"
SOXI_BIN="${SOXI_BIN:-/opt/homebrew/bin/soxi}"
# Pattern 2 boundary: the whisper-cli binary reference appears on exactly two
# lines — the assignment immediately below (with folded -x existence check)
# and the invocation inside transcribe() near line 79. This is the v1.1 swap
# site for the warm-process upgrade.
WHISPER_BIN="${WHISPER_BIN:-/opt/homebrew/bin/whisper-cli}"; [ -x "$WHISPER_BIN" ] || { echo "PurpleVoice: whisper-cli missing — run setup.sh" >&2; exit 11; }

# --- Paths (D-03 XDG layout) -------------------------------------------
MODEL="${PURPLEVOICE_MODEL:-$HOME/.local/share/voice-cc/models/ggml-small.en.bin}"
SILERO_MODEL="${PURPLEVOICE_SILERO_MODEL:-$HOME/.local/share/voice-cc/models/ggml-silero-v6.2.0.bin}"
VOCAB_FILE="$HOME/.config/voice-cc/vocab.txt"
DENYLIST="$HOME/.config/voice-cc/denylist.txt"
VAD_THRESHOLD="${PURPLEVOICE_VAD_THRESHOLD:-0.50}"
WAV_DIR="/tmp/voice-cc"
WAV="$WAV_DIR/recording.wav"
SOX_ERR_LOG="$WAV_DIR/sox.stderr"

mkdir -p "$WAV_DIR"

# --- Per-startup sweep of stale leftovers (>5 min old) -----------------
# Defends against SIGKILL exit paths (which don't fire EXIT trap).
find "$WAV_DIR" -maxdepth 1 -name "*.wav" -mmin +5 -delete 2>/dev/null || true
find "$WAV_DIR" -maxdepth 1 -name "*.txt" -mmin +5 -delete 2>/dev/null || true
find "$WAV_DIR" -maxdepth 1 -name "sox.stderr" -mmin +5 -delete 2>/dev/null || true

# --- EXIT trap covers ALL exit paths (success, exit codes, signals) ----
# Bash's EXIT trap fires on every exit including after signal-specific traps.
trap 'rm -f "$WAV" "$SOX_ERR_LOG"' EXIT

# --- Verify required model files exist (TRA-04, TRA-01) ----------------
# Exit 11 = binary or model missing (whisper-cli existence is folded onto the
# assignment line above to preserve the Pattern 2 boundary).
if [ ! -f "$MODEL" ]; then
  echo "PurpleVoice: Whisper model missing at $MODEL — run setup.sh" >&2
  exit 11
fi
if [ ! -f "$SILERO_MODEL" ]; then
  echo "PurpleVoice: Silero VAD weights missing at $SILERO_MODEL — run setup.sh" >&2
  exit 11
fi

# --- Read vocab if available (TRA-03) ----------------------------------
# Tolerate missing/unreadable vocab.txt — vocab is enhancement, not critical.
if [ -r "$VOCAB_FILE" ]; then
  VOCAB="$(cat "$VOCAB_FILE")"
else
  VOCAB=""
fi

# --- transcribe() — the SOLE STT abstraction boundary (Pattern 2) ------
# v1: one-shot whisper-cli with VAD + suppress-nst.
# v1.1 (deferred): swap body to `curl 127.0.0.1:8080/inference -F file=@"$1"`.
# NOTHING else in this script may invoke whisper-cli directly.
transcribe() {
  local wav_path="$1"
  "$WHISPER_BIN" \
    -m "$MODEL" \
    --language en \
    --no-timestamps \
    --no-prints \
    --vad \
    --vad-model "$SILERO_MODEL" \
    --vad-threshold "$VAD_THRESHOLD" \
    --suppress-nst \
    --prompt "$VOCAB" \
    -f "$wav_path" 2>/dev/null
}

# --- Capture: sox in background, signals forwarded for clean WAV finalise -
# PURPLEVOICE_TEST_SKIP_SOX=1 → skip capture (tests pre-stage the WAV).
if [ "${PURPLEVOICE_TEST_SKIP_SOX:-0}" != "1" ]; then
  : > "$SOX_ERR_LOG"   # initialise empty (so grep doesn't error)
  "$SOX_BIN" -d -r 16000 -c 1 -b 16 "$WAV" >/dev/null 2>"$SOX_ERR_LOG" &
  SOX_PID=$!
  # SOX_SIGNALED flags the trap-induced termination path (hotkey release).
  # That path produces a non-zero SOX_EXIT but is NOT a failure — sox
  # finalizes the WAV via its own SIGTERM handler. Distinguishing it from
  # a real sox failure is what stops the TCC-grep + exit-12 fall-through
  # from firing on every normal press-and-hold release.
  SOX_SIGNALED=0
  trap 'SOX_SIGNALED=1; kill -TERM "$SOX_PID" 2>/dev/null || true' TERM INT
  # CRITICAL: capture wait's exit status correctly. The naive masking pattern
  # (wait piped through "or-true" then $?) reads $? as 0 always because the
  # mask succeeded — making SOX_EXIT a dead variable and the TCC fingerprint
  # below dead code. Initialise SOX_EXIT to 0 first, then capture only on
  # failure so $? reflects wait's real exit code.
  SOX_EXIT=0
  wait "$SOX_PID" || SOX_EXIT=$?
  trap - TERM INT

  # --- TCC silent-deny detection (ROB-02) ------------------------------
  # Two failure modes on Apple Silicon, depending on macOS version:
  #
  #  (a) Legacy / edge case: sox exits non-zero with a CoreAudio error in
  #      stderr (Permission denied / AudioObject*PropertyData / kAudio.*).
  #      The grep below catches it.
  #
  #  (b) Sequoia 15.7.5+ (verified live 2026-04-28): macOS feeds sox a
  #      SILENT stream when TCC denies the mic — sox runs to completion,
  #      exits 0, no stderr error, but the WAV is at the 16-bit dither
  #      floor (~0.000031 max amplitude = 1 LSB). The amplitude check
  #      AFTER this block catches that path.
  #
  # Sox-died-for-real path:
  if [ "$SOX_EXIT" -ne 0 ] && [ "$SOX_SIGNALED" -ne 1 ]; then
    if grep -qE 'Permission denied|AudioObject(GetPropertyData|SetPropertyData)|kAudio.*Error' "$SOX_ERR_LOG" 2>/dev/null; then
      exit 10
    fi
    exit 12
  fi

  # Sequoia silent-stream path: inspect captured WAV amplitude. Real
  # microphones have a noise floor ~256× the dither floor; threshold
  # 0.0001 is 3× the dither floor, comfortably between the two regimes.
  # If sox stat fails to parse for any reason, skip the check (don't
  # false-positive on parse error — let downstream duration/empty gates
  # handle it).
  MAX_AMP=$("$SOX_BIN" "$WAV" -n stat 2>&1 | awk '/^Maximum amplitude:/ { print $3 }')
  if [ -n "$MAX_AMP" ] && awk -v m="$MAX_AMP" 'BEGIN { exit !(m+0 <= 0.0001) }'; then
    exit 10
  fi
fi

# --- Duration gate (TRA-05, success criterion #1) ----------------------
DURATION=$("$SOXI_BIN" -D "$WAV" 2>/dev/null || echo 0)
if awk -v d="$DURATION" 'BEGIN { exit !(d < 0.4) }'; then
  exit 2
fi

# --- Transcribe (Pattern 2 boundary — sole whisper-cli call) -----------
TRANSCRIPT="$(transcribe "$WAV")"
TRANSCRIPT="$(printf "%s" "$TRANSCRIPT" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

# --- Empty drop (INJ-04) -----------------------------------------------
if [ -z "$TRANSCRIPT" ]; then
  exit 3
fi

# --- Denylist exact-match (TRA-06) -------------------------------------
if [ -r "$DENYLIST" ]; then
  CANON_T="$(printf "%s" "$TRANSCRIPT" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')"
  while IFS= read -r phrase; do
    case "$phrase" in ''|'#'*) continue ;; esac
    CANON_P="$(printf "%s" "$phrase" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')"
    [ -z "$CANON_P" ] && continue
    if [ "$CANON_T" = "$CANON_P" ]; then
      exit 3
    fi
  done < "$DENYLIST"
fi

# --- Emit transcript (no trailing newline — caller pastes verbatim) ----
printf "%s" "$TRANSCRIPT"
